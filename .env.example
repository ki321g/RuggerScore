# Required: Postgres connection string (Neon recommended for Vercel)
# Use the **pooled** connection string from Neon and keep ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# Required: Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional: Web Push (VAPID). If unset, dev auto-generates and stores in the kv table.
# For production set both keys explicitly so they survive across instances.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
